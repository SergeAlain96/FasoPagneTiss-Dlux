rules_version = '2';

// Règles de sécurité Firestore — FasoPagnes Tissé D'lux
// À copier dans : Console Firebase > Firestore Database > Règles > Publier
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Produits ──
    // Lecture publique (la boutique doit s'afficher pour tout le monde).
    // Écriture réservée à l'administrateur connecté (Firebase Auth).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Commandes ──
    // Un visiteur peut CRÉER une commande (sans compte), mais seul l'admin
    // connecté peut les lire, les modifier ou les supprimer.
    // La création est validée : champs obligatoires + statut initial imposé.
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(
                        ['clientName', 'clientPhone', 'items', 'status', 'createdAt'])
                    && request.resource.data.status == 'en attente'
                    && request.resource.data.clientName is string
                    && request.resource.data.clientPhone is string;
      allow read, update, delete: if request.auth != null;
    }

    // ── Ancien format (document unique) — transition & migration ──
    // Les produits restent lisibles publiquement le temps de la migration.
    // Les commandes héritées (avec n° de téléphone) ne sont accessibles
    // qu'à l'admin. Ces documents servent aussi de sauvegarde.
    match /fasopagnes/products {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /fasopagnes/orders {
      allow read, write: if request.auth != null;
    }

    // Tout le reste est interdit par défaut.
  }
}
